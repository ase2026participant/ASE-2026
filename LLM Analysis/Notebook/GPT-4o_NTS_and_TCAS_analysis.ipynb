        "def get_system_prompt():\n",
        "    return (\n",
        "        \"You are a precise coding assistant. Determine if two C code snippets differ functionally.\\n\"\n",
        "        \"Ignore all differences that only affect printf: this includes changes in printed text or conditions that only determine which printf is executed.\\n\"\n",
        "        \"Only consider functional differences if the change affects control flow (e.g., code execution), data values, function results, or side effects other than output.\\n\"\n",
