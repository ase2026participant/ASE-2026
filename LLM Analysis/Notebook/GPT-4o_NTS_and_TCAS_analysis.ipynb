        "no_NTS_example_feasible_for_GPT4_turbo = len(prompt_size_df[(prompt_size_df['prompt tokens'] > 32768) & (prompt_size_df['prompt tokens'] <= 128000)])\n",
        "no_NTS_example_not_feasible = len(prompt_size_df[prompt_size_df['prompt tokens'] > 128000])\n",
