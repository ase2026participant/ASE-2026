      "id": "f935a648-e97d-4252-b29d-5b248d13f7fd",
      "metadata": {},
      "outputs": [],
      "source": [
        "def get_user_prompt(source,mutant):\n",
        "    prompt = f\"Here is the original (source) code:\\n\\n{source}\\n\\nAnd here is the mutated version of the code:\\n\\n{mutant}\\n\\nDo these two pieces of code have any **functional difference**? Respond strictly with \\\"Yes\\\" or \\\"No\\\" only. Explain your answer in single line if required provide code responsible with line number in mutant, if there are multiple discrepancies each will have one line explanation.\"\n",
        "    return prompt"
      ]
    },
    {
